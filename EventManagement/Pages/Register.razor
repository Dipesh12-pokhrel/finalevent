@page "/register"
@layout AuthLayout
@inject AuthService AuthSvc
@inject SessionService Session
@inject NavigationManager Nav
@inject ProtectedLocalStorage Storage

<PageTitle>Register – EventHub</PageTitle>

<div class="auth-card" style="max-width:480px">
    <div class="auth-logo" style="background:linear-gradient(135deg,#10b981,#059669)">
        <i class="fas fa-user-plus"></i>
    </div>
    <h1 class="auth-title">Create Account</h1>
    <p class="auth-subtitle">Join EventHub and discover amazing events</p>

    @if (!string.IsNullOrEmpty(errorMsg))
    {
        <div class="alert alert-danger mb-3">
            <i class="fas fa-exclamation-circle me-2"></i>@errorMsg
            <button type="button" class="btn-close float-end" @onclick="() => errorMsg = null"></button>
        </div>
    }

    <EditForm Model="model" OnValidSubmit="HandleRegister">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label class="form-label">Full Name</label>
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-user"></i></span>
                <InputText class="form-control" @bind-Value="model.FullName" placeholder="Your full name" />
            </div>
            <ValidationMessage For="@(() => model.FullName)" class="text-danger small mt-1" />
        </div>
        <div class="mb-3">
            <label class="form-label">Email Address</label>
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                <InputText class="form-control" @bind-Value="model.Email" placeholder="your@email.com" />
            </div>
            <ValidationMessage For="@(() => model.Email)" class="text-danger small mt-1" />
        </div>
        <div class="mb-3">
            <label class="form-label">Password</label>
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-lock"></i></span>
                <InputText type="password" class="form-control" @bind-Value="model.Password" placeholder="Min 6 characters" />
            </div>
            <ValidationMessage For="@(() => model.Password)" class="text-danger small mt-1" />
        </div>
        <div class="mb-4">
            <label class="form-label">Confirm Password</label>
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-lock"></i></span>
                <InputText type="password" class="form-control" @bind-Value="model.ConfirmPassword" placeholder="Re-enter password" />
            </div>
            <ValidationMessage For="@(() => model.ConfirmPassword)" class="text-danger small mt-1" />
        </div>

        <button type="submit" class="btn btn-success w-100 py-2" disabled="@loading">
            @if (loading) { <span class="spinner-border spinner-border-sm me-2"></span><span>Creating account…</span> }
            else          { <i class="fas fa-user-plus me-2"></i><span>Create Account</span> }
        </button>
    </EditForm>

    <div class="auth-divider">or</div>
    <p class="text-center mb-0 small">
        Already have an account? <a href="/login" class="fw-semibold text-primary text-decoration-none">Sign in</a>
    </p>
</div>

@code {
    private RegisterModel model = new();
    private string? errorMsg;
    private bool loading;

    protected override void OnInitialized()
    {
        if (Session.IsAuthenticated) Nav.NavigateTo("/");
    }

    private async Task HandleRegister()
    {
        if (model.Password != model.ConfirmPassword) { errorMsg = "Passwords do not match."; return; }
        loading = true; errorMsg = null;
        var (ok, msg, user) = await AuthSvc.RegisterAsync(model.FullName, model.Email, model.Password);
        loading = false;
        if (ok && user != null)
        {
            Session.SetUser(user);
            try { await Storage.SetAsync("userId", user.Id); } catch { }
            Nav.NavigateTo("/");
        }
        else { errorMsg = msg; }
    }

    private class RegisterModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Full name is required")]
        [System.ComponentModel.DataAnnotations.MaxLength(100)]
        public string FullName { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Invalid email")]
        public string Email { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required")]
        [System.ComponentModel.DataAnnotations.MinLength(6, ErrorMessage = "Min 6 characters")]
        public string Password { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please confirm your password")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
