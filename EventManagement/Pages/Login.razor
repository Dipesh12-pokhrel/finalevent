@page "/login"
@layout AuthLayout
@inject AuthService AuthSvc
@inject SessionService Session
@inject NavigationManager Nav
@inject ProtectedLocalStorage Storage

<PageTitle>Login – EventHub</PageTitle>

<div class="auth-card">
    <div class="auth-logo"><i class="fas fa-calendar-check"></i></div>
    <h1 class="auth-title">Welcome Back</h1>
    <p class="auth-subtitle">Sign in to your EventHub account</p>

    @if (!string.IsNullOrEmpty(errorMsg))
    {
        <div class="alert alert-danger mb-3">
            <i class="fas fa-exclamation-circle me-2"></i>@errorMsg
            <button type="button" class="btn-close float-end" @onclick="() => errorMsg = null"></button>
        </div>
    }

    <EditForm Model="model" OnValidSubmit="HandleLogin">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label class="form-label">Email Address</label>
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                <InputText class="form-control" @bind-Value="model.Email" placeholder="admin@event.com" />
            </div>
            <ValidationMessage For="@(() => model.Email)" class="text-danger small mt-1" />
        </div>

        <div class="mb-4">
            <label class="form-label">Password</label>
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-lock"></i></span>
                <InputText type="password" class="form-control" @bind-Value="model.Password" placeholder="Enter your password" />
            </div>
            <ValidationMessage For="@(() => model.Password)" class="text-danger small mt-1" />
        </div>

        <button type="submit" class="btn btn-primary w-100 py-2" disabled="@loading">
            @if (loading) { <span class="spinner-border spinner-border-sm me-2"></span><span>Signing in…</span> }
            else          { <i class="fas fa-sign-in-alt me-2"></i><span>Sign In</span> }
        </button>
    </EditForm>

    <div class="auth-divider">or</div>
    <p class="text-center mb-0 small">
        Don't have an account? <a href="/register" class="fw-semibold text-primary text-decoration-none">Create one</a>
    </p>
    <div class="admin-hint">
        <i class="fas fa-shield-alt me-1"></i>
        Admin: <strong>admin@event.com</strong> / <strong>Admin@123</strong>
    </div>
</div>

@code {
    private LoginModel model = new();
    private string? errorMsg;
    private bool loading;

    protected override void OnInitialized()
    {
        if (Session.IsAuthenticated) Nav.NavigateTo("/");
    }

    private async Task HandleLogin()
    {
        loading = true; errorMsg = null;
        var (ok, msg, user) = await AuthSvc.LoginAsync(model.Email, model.Password);
        loading = false;
        if (ok && user != null)
        {
            Session.SetUser(user);
            try { await Storage.SetAsync("userId", user.Id); } catch { }
            Nav.NavigateTo("/");
        }
        else { errorMsg = msg; }
    }

    private class LoginModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Invalid email")]
        public string Email { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = string.Empty;
    }
}
