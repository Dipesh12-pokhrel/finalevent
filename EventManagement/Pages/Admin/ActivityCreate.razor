@page "/admin/activities/create"
@inject ActivityService ActSvc
@inject SessionService Session
@inject NavigationManager Nav

<PageTitle>Add Activity – EventHub</PageTitle>

@if (!Session.IsAdmin)
{
    <div class="container mt-5"><div class="alert alert-danger"><i class="fas fa-ban me-2"></i>Access denied.</div></div>
}
else
{
    <div class="container">
        <nav aria-label="breadcrumb" class="mt-2 mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/admin/activities">Activities</a></li>
                <li class="breadcrumb-item active">Add Activity</li>
            </ol>
        </nav>
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="card">
                    <div class="card-header py-3" style="background:linear-gradient(135deg,var(--primary),var(--secondary));color:#fff">
                        <h5 class="mb-0"><i class="fas fa-tasks me-2"></i>Add New Activity</h5>
                    </div>
                    <div class="card-body p-4">
                        @if (!string.IsNullOrEmpty(err)) { <div class="alert alert-danger">@err</div> }
                        <EditForm Model="model" OnValidSubmit="HandleCreate">
                            <DataAnnotationsValidator />
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label">Activity Name *</label>
                                    <InputText class="form-control" @bind-Value="model.Name" placeholder="e.g. AI/ML Workshop" />
                                    <ValidationMessage For="@(() => model.Name)" class="text-danger small" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Type *</label>
                                    <InputSelect class="form-select" @bind-Value="model.Type">
                                        <option>Workshop</option><option>Talk</option>
                                        <option>Panel</option><option>Demo</option>
                                        <option>Game</option><option>Networking</option>
                                        <option>Competition</option><option>Wellness</option>
                                        <option>Other</option>
                                    </InputSelect>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Duration (minutes) *</label>
                                    <InputNumber class="form-control" @bind-Value="model.DurationMinutes" />
                                    <ValidationMessage For="@(() => model.DurationMinutes)" class="text-danger small" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Description</label>
                                    <InputTextArea class="form-control" @bind-Value="model.Description" rows="3" placeholder="Brief description of the activity..." />
                                </div>
                            </div>
                            <div class="d-flex gap-2 mt-4">
                                <button type="submit" class="btn btn-primary" disabled="@saving">
                                    @if (saving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                                    <i class="fas fa-save me-1"></i>Save Activity
                                </button>
                                <a href="/admin/activities" class="btn btn-outline-secondary">Cancel</a>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private ActivityForm model = new() { DurationMinutes = 60 };
    private string? err;
    private bool saving;

    protected override void OnInitialized()
    {
        if (!Session.IsAuthenticated) Nav.NavigateTo("/login");
    }

    private async Task HandleCreate()
    {
        saving = true; err = null;
        try
        {
            await ActSvc.CreateAsync(new Activity
            {
                Name = model.Name, Type = model.Type,
                DurationMinutes = model.DurationMinutes, Description = model.Description
            });
            Nav.NavigateTo("/admin/activities");
        }
        catch (Exception ex) { err = "Error: " + ex.Message; saving = false; }
    }

    private class ActivityForm
    {
        [System.ComponentModel.DataAnnotations.Required] public string Name { get; set; } = string.Empty;
        public string Type { get; set; } = "Workshop";
        [System.ComponentModel.DataAnnotations.Range(1,1440)] public int DurationMinutes { get; set; } = 60;
        public string? Description { get; set; }
    }
}
