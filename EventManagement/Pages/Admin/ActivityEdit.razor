@page "/admin/activities/edit/{Id:int}"
@inject ActivityService ActSvc
@inject SessionService Session
@inject NavigationManager Nav

<PageTitle>Edit Activity – EventHub</PageTitle>

@if (!Session.IsAdmin) { <div class="container mt-5"><div class="alert alert-danger"><i class="fas fa-ban me-2"></i>Access denied.</div></div> }
else if (model == null) { <div class="container text-center py-5"><div class="spinner-border text-primary"></div></div> }
else
{
    <div class="container">
        <nav aria-label="breadcrumb" class="mt-2 mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/admin/activities">Activities</a></li>
                <li class="breadcrumb-item active">Edit</li>
            </ol>
        </nav>
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="card">
                    <div class="card-header py-3" style="background:linear-gradient(135deg,#f59e0b,#d97706);color:#fff">
                        <h5 class="mb-0"><i class="fas fa-edit me-2"></i>Edit Activity</h5>
                    </div>
                    <div class="card-body p-4">
                        @if (!string.IsNullOrEmpty(err)) { <div class="alert alert-danger">@err</div> }
                        <EditForm Model="model" OnValidSubmit="HandleEdit">
                            <DataAnnotationsValidator />
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label">Activity Name *</label>
                                    <InputText class="form-control" @bind-Value="model.Name" />
                                    <ValidationMessage For="@(() => model.Name)" class="text-danger small" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Type</label>
                                    <InputSelect class="form-select" @bind-Value="model.Type">
                                        <option>Workshop</option><option>Talk</option>
                                        <option>Panel</option><option>Demo</option>
                                        <option>Game</option><option>Networking</option>
                                        <option>Competition</option><option>Wellness</option>
                                        <option>Other</option>
                                    </InputSelect>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Duration (minutes)</label>
                                    <InputNumber class="form-control" @bind-Value="model.DurationMinutes" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Description</label>
                                    <InputTextArea class="form-control" @bind-Value="model.Description" rows="3" />
                                </div>
                            </div>
                            <div class="d-flex gap-2 mt-4">
                                <button type="submit" class="btn btn-warning" disabled="@saving">
                                    @if (saving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                                    <i class="fas fa-save me-1"></i>Save Changes
                                </button>
                                <a href="/admin/activities" class="btn btn-outline-secondary">Cancel</a>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private ActivityForm? model;
    private string? err;
    private bool saving;

    protected override async Task OnParametersSetAsync()
    {
        if (!Session.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        var a = await ActSvc.GetByIdAsync(Id);
        if (a == null) { Nav.NavigateTo("/admin/activities"); return; }
        model = new ActivityForm { Name = a.Name, Type = a.Type, DurationMinutes = a.DurationMinutes, Description = a.Description };
    }

    private async Task HandleEdit()
    {
        saving = true; err = null;
        try
        {
            await ActSvc.UpdateAsync(new Activity { Id = Id, Name = model!.Name, Type = model.Type, DurationMinutes = model.DurationMinutes, Description = model.Description });
            Nav.NavigateTo("/admin/activities");
        }
        catch (Exception ex) { err = "Error: " + ex.Message; saving = false; }
    }

    private class ActivityForm
    {
        [System.ComponentModel.DataAnnotations.Required] public string Name { get; set; } = string.Empty;
        public string Type { get; set; } = "Workshop";
        [System.ComponentModel.DataAnnotations.Range(1,1440)] public int DurationMinutes { get; set; } = 60;
        public string? Description { get; set; }
    }
}
