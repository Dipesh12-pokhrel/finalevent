@page "/admin"
@inject EventService EventSvc
@inject RegistrationService RegSvc
@inject VenueService VenueSvc
@inject ActivityService ActSvc
@inject ParticipantService ParticipantSvc
@inject SessionService Session
@inject NavigationManager Nav

<PageTitle>Admin Dashboard – EventHub</PageTitle>

@if (!Session.IsAdmin)
{
    <div class="container mt-5">
        <div class="alert alert-danger"><i class="fas fa-ban me-2"></i>Access denied. Admins only.</div>
    </div>
}
else
{
    <div class="container-fluid">
        <div class="page-header">
            <div>
                <h2 class="section-title mb-1"><i class="fas fa-tachometer-alt text-primary me-2"></i>Admin Dashboard</h2>
                <p class="section-subtitle mb-0">Welcome back, @Session.CurrentUser!.FullName!</p>
            </div>
            <a href="/events/create" class="btn btn-primary"><i class="fas fa-plus me-1"></i>New Event</a>
        </div>

        <!-- Stats -->
        @if (events != null && venues != null && activities != null && participants != null)
        {
            var totalRegs  = events.Sum(e => e.Registrations.Count(r => r.Status == RegistrationStatus.Confirmed));
            var upcoming   = events.Count(e => e.EventDate >= DateTime.UtcNow);
            var fullyBooked= events.Count(e => e.Registrations.Count(r => r.Status != RegistrationStatus.Cancelled) >= e.MaxCapacity);

            <div class="row g-4 mb-4">
                <div class="col-md-3 col-6">
                    <div class="stat-card text-white" style="background:linear-gradient(135deg,#6366f1,#8b5cf6);animation-delay:.05s">
                        <div class="d-flex justify-content-between align-items-center">
                            <div><div class="stat-val">@events.Count</div><div class="stat-label">Total Events</div></div>
                            <i class="fas fa-calendar-alt stat-icon"></i>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="stat-card text-white" style="background:linear-gradient(135deg,#10b981,#059669);animation-delay:.1s">
                        <div class="d-flex justify-content-between align-items-center">
                            <div><div class="stat-val">@upcoming</div><div class="stat-label">Upcoming</div></div>
                            <i class="fas fa-clock stat-icon"></i>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="stat-card text-white" style="background:linear-gradient(135deg,#0ea5e9,#06b6d4);animation-delay:.15s">
                        <div class="d-flex justify-content-between align-items-center">
                            <div><div class="stat-val">@totalRegs</div><div class="stat-label">Registrations</div></div>
                            <i class="fas fa-users stat-icon"></i>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="stat-card text-white" style="background:linear-gradient(135deg,#f59e0b,#d97706);animation-delay:.2s">
                        <div class="d-flex justify-content-between align-items-center">
                            <div><div class="stat-val">@fullyBooked</div><div class="stat-label">Fully Booked</div></div>
                            <i class="fas fa-ban stat-icon"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Second row -->
            <div class="row g-4 mb-4">
                <div class="col-md-3 col-6">
                    <a href="/admin/venues" class="text-decoration-none">
                        <div class="card p-3 h-100 text-center" style="transition:var(--trans);cursor:pointer" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform=''">
                            <div style="width:50px;height:50px;border-radius:14px;background:linear-gradient(135deg,#0ea5e9,#06b6d4);display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#fff;margin:0 auto .75rem">
                                <i class="fas fa-building"></i>
                            </div>
                            <div class="fw-800" style="font-size:1.6rem;color:var(--dark-2)">@venues.Count</div>
                            <div class="text-muted small">Venues</div>
                        </div>
                    </a>
                </div>
                <div class="col-md-3 col-6">
                    <a href="/admin/activities" class="text-decoration-none">
                        <div class="card p-3 h-100 text-center" style="transition:var(--trans);cursor:pointer" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform=''">
                            <div style="width:50px;height:50px;border-radius:14px;background:linear-gradient(135deg,#8b5cf6,#7c3aed);display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#fff;margin:0 auto .75rem">
                                <i class="fas fa-tasks"></i>
                            </div>
                            <div class="fw-800" style="font-size:1.6rem;color:var(--dark-2)">@activities.Count</div>
                            <div class="text-muted small">Activities</div>
                        </div>
                    </a>
                </div>
                <div class="col-md-3 col-6">
                    <a href="/admin/participants" class="text-decoration-none">
                        <div class="card p-3 h-100 text-center" style="transition:var(--trans);cursor:pointer" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform=''">
                            <div style="width:50px;height:50px;border-radius:14px;background:linear-gradient(135deg,#10b981,#059669);display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#fff;margin:0 auto .75rem">
                                <i class="fas fa-users"></i>
                            </div>
                            <div class="fw-800" style="font-size:1.6rem;color:var(--dark-2)">@participants.Count</div>
                            <div class="text-muted small">Participants</div>
                        </div>
                    </a>
                </div>
                <div class="col-md-3 col-6">
                    <div class="card p-3 h-100 text-center">
                        <div style="width:50px;height:50px;border-radius:14px;background:linear-gradient(135deg,#ef4444,#dc2626);display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#fff;margin:0 auto .75rem">
                            <i class="fas fa-fire"></i>
                        </div>
                        <div class="fw-800" style="font-size:1.6rem;color:var(--dark-2)">@(events.Count > 0 ? (int)((double)totalRegs / events.Count) : 0)</div>
                        <div class="text-muted small">Avg Registrations/Event</div>
                    </div>
                </div>
            </div>
        }

        <!-- Events Table -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 fw-bold"><i class="fas fa-list me-2 text-primary"></i>All Events</h5>
        </div>

        @if (events == null)
        {
            <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
        }
        else if (!events.Any())
        {
            <div class="alert alert-info">No events yet. <a href="/events/create">Create one!</a></div>
        }
        else
        {
            <div class="card">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>Event</th>
                                <th>Category</th>
                                <th>Date</th>
                                <th>Venues</th>
                                <th>Activities</th>
                                <th>Registrations</th>
                                <th>Status</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ev in events.OrderBy(e => e.EventDate))
                            {
                                var isPast  = ev.EventDate < DateTime.UtcNow;
                                var activeR = ev.Registrations.Count(r => r.Status != RegistrationStatus.Cancelled);
                                var fill    = ev.MaxCapacity > 0 ? (int)((double)activeR / ev.MaxCapacity * 100) : 0;
                                var catKey  = (ev.Category ?? "general").ToLower().Replace(" ","");
                                <tr class="@(isPast ? "text-muted" : "")">
                                    <td class="small">@ev.Id</td>
                                    <td>
                                        <a href="/events/@ev.Id" class="fw-600 text-decoration-none">@ev.Title</a>
                                    </td>
                                    <td><span class="badge" style="background:rgba(99,102,241,.12);color:var(--primary)">@ev.Category</span></td>
                                    <td class="small">@ev.EventDate.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                    <td>
                                        @foreach (var v in ev.EventVenues.Take(2))
                                        { <span class="pill-tag venue d-inline-block mb-1">@v.Venue.City</span> }
                                        @if (ev.EventVenues.Count > 2) { <span class="pill-tag">+@(ev.EventVenues.Count-2)</span> }
                                    </td>
                                    <td><span class="badge" style="background:#f5f3ff;color:#7c3aed">@ev.EventActivities.Count acts</span></td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <span style="min-width:28px">@activeR</span>
                                            <div class="progress flex-grow-1" style="height:5px;min-width:60px">
                                                <div class="progress-bar @(fill>=90?"bg-danger":fill>=70?"bg-warning":"bg-success")" style="width:@fill%"></div>
                                            </div>
                                            <span class="small text-muted">/@ev.MaxCapacity</span>
                                        </div>
                                    </td>
                                    <td>
                                        @if (isPast) { <span class="badge bg-secondary">Past</span> }
                                        else if (activeR >= ev.MaxCapacity) { <span class="badge bg-danger">Full</span> }
                                        else { <span class="badge bg-success">Open</span> }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <a href="/events/@ev.Id" class="btn btn-outline-primary" title="View"><i class="fas fa-eye"></i></a>
                                            <a href="/events/edit/@ev.Id" class="btn btn-outline-warning" title="Edit"><i class="fas fa-edit"></i></a>
                                            <a href="/events/delete/@ev.Id" class="btn btn-outline-danger" title="Delete"><i class="fas fa-trash"></i></a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Event>?    events;
    private List<Venue>?    venues;
    private List<Activity>? activities;
    private List<User>?     participants;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        events       = await EventSvc.GetAllEventsAsync();
        venues       = await VenueSvc.GetAllAsync();
        activities   = await ActSvc.GetAllAsync();
        participants = await ParticipantSvc.GetAllAsync();
    }
}
