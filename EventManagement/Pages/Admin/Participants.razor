@page "/admin/participants"
@inject ParticipantService ParticipantSvc
@inject SessionService Session
@inject NavigationManager Nav

<PageTitle>Participants – EventHub</PageTitle>

@if (!Session.IsAdmin)
{
    <div class="container mt-5"><div class="alert alert-danger"><i class="fas fa-ban me-2"></i>Access denied.</div></div>
}
else
{
    <div class="container-fluid">
        <div class="page-header">
            <div>
                <h2 class="section-title mb-1"><i class="fas fa-users text-primary me-2"></i>Participants</h2>
                <p class="section-subtitle mb-0">Manage registered participants and their event registrations</p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(msg))
        {
            <div class="alert alert-@msgType alert-dismissible">@msg <button type="button" class="btn-close" @onclick="() => msg = null"></button></div>
        }

        @if (users == null)
        {
            <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
        }
        else if (!users.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon"><i class="fas fa-users"></i></div>
                <h6>No participants yet</h6>
            </div>
        }
        else
        {
            <!-- Summary stats -->
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="stat-card text-white" style="background:linear-gradient(135deg,#6366f1,#8b5cf6)">
                        <div class="d-flex justify-content-between align-items-center">
                            <div><div class="stat-val">@users.Count</div><div class="stat-label">Total Participants</div></div>
                            <i class="fas fa-users stat-icon"></i>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card text-white" style="background:linear-gradient(135deg,#10b981,#059669)">
                        <div class="d-flex justify-content-between align-items-center">
                            <div><div class="stat-val">@users.Count(u => !u.IsAdmin)</div><div class="stat-label">Regular Users</div></div>
                            <i class="fas fa-user stat-icon"></i>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card text-white" style="background:linear-gradient(135deg,#f59e0b,#d97706)">
                        <div class="d-flex justify-content-between align-items-center">
                            <div><div class="stat-val">@users.Count(u => u.IsAdmin)</div><div class="stat-label">Administrators</div></div>
                            <i class="fas fa-crown stat-icon"></i>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card text-white" style="background:linear-gradient(135deg,#0ea5e9,#06b6d4)">
                        <div class="d-flex justify-content-between align-items-center">
                            <div><div class="stat-val">@users.Sum(u => u.Registrations.Count)</div><div class="stat-label">Total Registrations</div></div>
                            <i class="fas fa-ticket-alt stat-icon"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Registrations</th>
                                <th>Joined</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in users.OrderBy(u => u.FullName))
                            {
                                <tr style="animation:fadeInUp .4s ease both">
                                    <td class="text-muted small">@u.Id</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#6366f1,#8b5cf6);display:flex;align-items:center;justify-content:center;color:#fff;font-size:.8rem;font-weight:700;flex-shrink:0">
                                                @u.FullName[0].ToString().ToUpper()
                                            </div>
                                            <span class="fw-600">@u.FullName</span>
                                        </div>
                                    </td>
                                    <td class="small text-muted">@u.Email</td>
                                    <td>
                                        @if (u.IsAdmin)
                                        { <span class="badge" style="background:linear-gradient(135deg,#f59e0b,#d97706);color:#fff"><i class="fas fa-crown me-1"></i>Admin</span> }
                                        else
                                        { <span class="badge" style="background:#e0e7ff;color:#4338ca">User</span> }
                                    </td>
                                    <td>
                                        <span class="badge" style="background:#f0fdf4;color:#166534;border:1px solid #bbf7d0">
                                            @u.Registrations.Count events
                                        </span>
                                    </td>
                                    <td class="small text-muted">@u.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            @if (!u.IsAdmin && u.Id != Session.CurrentUser!.Id)
                                            {
                                                <button class="btn btn-outline-warning" @onclick="() => ToggleAdmin(u.Id, true)" title="Make Admin">
                                                    <i class="fas fa-crown"></i>
                                                </button>
                                            }
                                            @if (u.IsAdmin && u.Id != Session.CurrentUser!.Id)
                                            {
                                                <button class="btn btn-outline-secondary" @onclick="() => ToggleAdmin(u.Id, false)" title="Remove Admin">
                                                    <i class="fas fa-user"></i>
                                                </button>
                                            }
                                            @if (u.Id != Session.CurrentUser!.Id)
                                            {
                                                <button class="btn btn-outline-danger" @onclick="() => DeleteUser(u.Id)" title="Delete">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<User>? users;
    private string? msg;
    private string msgType = "success";

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        users = await ParticipantSvc.GetAllAsync();
    }

    private async Task ToggleAdmin(int id, bool makeAdmin)
    {
        await ParticipantSvc.UpdateStatusAsync(id, makeAdmin);
        msg = makeAdmin ? "User promoted to Admin." : "Admin role removed.";
        msgType = "success";
        users = await ParticipantSvc.GetAllAsync();
    }

    private async Task DeleteUser(int id)
    {
        var ok = await ParticipantSvc.DeleteAsync(id);
        msg = ok ? "Participant deleted." : "Could not delete participant.";
        msgType = ok ? "success" : "danger";
        users = await ParticipantSvc.GetAllAsync();
    }
}
