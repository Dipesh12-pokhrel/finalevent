@page "/admin/venues"
@inject VenueService VenueSvc
@inject SessionService Session
@inject NavigationManager Nav

<PageTitle>Manage Venues – EventHub</PageTitle>

@if (!Session.IsAdmin)
{
    <div class="container mt-5"><div class="alert alert-danger"><i class="fas fa-ban me-2"></i>Access denied.</div></div>
}
else
{
    <div class="container-fluid">
        <div class="page-header">
            <div>
                <h2 class="section-title mb-1"><i class="fas fa-building text-primary me-2"></i>Venues</h2>
                <p class="section-subtitle mb-0">Manage event venues and locations</p>
            </div>
            <a href="/admin/venues/create" class="btn btn-primary"><i class="fas fa-plus me-1"></i>Add Venue</a>
        </div>

        @if (!string.IsNullOrEmpty(msg))
        {
            <div class="alert alert-@msgType alert-dismissible">
                @msg <button type="button" class="btn-close" @onclick="() => msg = null"></button>
            </div>
        }

        @if (venues == null)
        {
            <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
        }
        else if (!venues.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon"><i class="fas fa-building"></i></div>
                <h6>No venues yet</h6>
                <a href="/admin/venues/create" class="btn btn-primary mt-2"><i class="fas fa-plus me-1"></i>Add First Venue</a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var v in venues)
                {
                    <div class="col-md-4">
                        <div class="card h-100" style="animation:fadeInUp .5s ease both">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-start justify-content-between mb-2">
                                    <div style="width:44px;height:44px;border-radius:11px;background:linear-gradient(135deg,#0ea5e9,#06b6d4);display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.1rem;flex-shrink:0">
                                        <i class="fas fa-building"></i>
                                    </div>
                                    <span class="badge" style="background:#e0f2fe;color:#0369a1">@v.City</span>
                                </div>
                                <h6 class="fw-bold mt-2 mb-1">@v.Name</h6>
                                <p class="text-muted small mb-2"><i class="fas fa-map-pin me-1"></i>@v.Address</p>
                                @if (!string.IsNullOrEmpty(v.Description))
                                {
                                    <p class="text-muted small mb-2">@(v.Description.Length > 80 ? v.Description[..80] + "…" : v.Description)</p>
                                }
                                <div class="d-flex align-items-center gap-2 mb-3">
                                    <span class="pill-tag"><i class="fas fa-users"></i>Cap: @v.Capacity</span>
                                    <span class="pill-tag"><i class="fas fa-calendar-alt"></i>@v.EventVenues.Count events</span>
                                </div>
                            </div>
                            <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-4 d-flex gap-2">
                                <a href="/admin/venues/edit/@v.Id" class="btn btn-warning btn-sm flex-grow-1">
                                    <i class="fas fa-edit me-1"></i>Edit
                                </a>
                                <button class="btn btn-danger btn-sm" @onclick="() => DeleteVenue(v.Id)" disabled="@deleting">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    private List<Venue>? venues;
    private string? msg;
    private string msgType = "success";
    private bool deleting;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        venues = await VenueSvc.GetAllAsync();
    }

    private async Task DeleteVenue(int id)
    {
        deleting = true;
        var ok = await VenueSvc.DeleteAsync(id);
        msg = ok ? "Venue deleted." : "Could not delete venue (it may be linked to events).";
        msgType = ok ? "success" : "danger";
        venues = await VenueSvc.GetAllAsync();
        deleting = false;
    }
}
