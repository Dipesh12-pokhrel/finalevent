@page "/events"
@inject EventService EventSvc
@inject SessionService Session

<PageTitle>Events – EventHub</PageTitle>

<div class="container">
    <div class="page-header">
        <div>
            <h2 class="section-title mb-1"><i class="fas fa-calendar-alt text-primary me-2"></i>All Events</h2>
            <p class="section-subtitle mb-0">Browse and register for upcoming events</p>
        </div>
        @if (Session.IsAdmin)
        {
            <a href="/events/create" class="btn btn-primary"><i class="fas fa-plus me-1"></i>New Event</a>
        }
    </div>

    <!-- Filters -->
    <div class="filter-card">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" class="form-control" placeholder="Search events…"
                           @bind="search" @bind:event="oninput" />
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="catFilter">
                    <option value="">All Categories</option>
                    <option>Technology</option><option>Business</option>
                    <option>Health</option><option>Education</option>
                    <option>Entertainment</option><option>General</option>
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="venueFilter">
                    <option value="">All Venues</option>
                    @foreach (var v in AllVenues)
                    {
                        <option value="@v">@v</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select" @bind="timeFilter">
                    <option value="upcoming">Upcoming</option>
                    <option value="past">Past</option>
                    <option value="all">All</option>
                </select>
            </div>
        </div>
    </div>

    @if (events == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-3 text-muted">Loading…</p>
        </div>
    }
    else if (!Filtered.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon"><i class="fas fa-calendar-times"></i></div>
            <h6>No events match your filters</h6>
            <p class="small">Try adjusting the search or filters above.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var ev in Filtered)
            {
                var catKey   = (ev.Category ?? "general").ToLower().Replace(" ", "");
                var icon     = ev.Category switch {
                    "Technology"    => "fa-microchip",
                    "Business"      => "fa-briefcase",
                    "Health"        => "fa-heartbeat",
                    "Education"     => "fa-graduation-cap",
                    "Entertainment" => "fa-music",
                    _               => "fa-calendar-alt"
                };
                var fill     = ev.MaxCapacity > 0 ? (int)((double)ev.Registrations.Count / ev.MaxCapacity * 100) : 0;
                var venues   = ev.EventVenues.Select(v => v.Venue.Name).ToList();
                var actTypes = ev.EventActivities.Select(a => a.Activity.Type).Distinct().ToList();
                <div class="col-md-4">
                    <div class="card h-100 event-card">
                        <div class="event-img-wrap cat-@catKey">
                            @if (!string.IsNullOrEmpty(ev.ImageUrl))
                            {
                                <img src="@ev.ImageUrl" alt="@ev.Title"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                <div class="event-img-fallback" style="display:none">
                                    <i class="fas @icon fa-2x"></i>
                                </div>
                            }
                            else
                            {
                                <div class="event-img-fallback">
                                    <i class="fas @icon fa-2x"></i>
                                </div>
                            }
                            <div class="event-img-overlay">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="badge" style="background:rgba(255,255,255,.25);color:#fff;backdrop-filter:blur(4px)">@ev.Category</span>
                                    <span style="color:rgba(255,255,255,.9);font-size:.78rem;background:rgba(0,0,0,.35);padding:.15rem .5rem;border-radius:50px">
                                        <i class="fas fa-users me-1"></i>@ev.Registrations.Count/@ev.MaxCapacity
                                    </span>
                                </div>
                                <div class="cap-bar mt-1"><div class="cap-bar-fill" style="width:@fill%"></div></div>
                            </div>
                        </div>
                        <div class="card-body d-flex flex-column p-3">
                            <h5 class="fw-bold mb-2" style="font-size:.97rem">@ev.Title</h5>
                            <p class="text-muted small flex-grow-1 mb-2" style="font-size:.83rem;line-height:1.5">
                                @(ev.Description.Length > 110 ? ev.Description[..110] + "…" : ev.Description)
                            </p>
                            @if (venues.Any())
                            {
                                <div class="mb-1">
                                    @foreach (var v in venues.Take(2))
                                    { <span class="pill-tag venue"><i class="fas fa-map-marker-alt"></i>@v</span> }
                                    @if (venues.Count > 2) { <span class="pill-tag">+@(venues.Count-2)</span> }
                                </div>
                            }
                            @if (actTypes.Any())
                            {
                                <div class="mb-2">
                                    @foreach (var t in actTypes.Take(3))
                                    {
                                        var tc = "act-" + t.ToLower();
                                        <span class="pill-tag @tc"><i class="fas fa-tag"></i>@t</span>
                                    }
                                </div>
                            }
                            <div class="small text-muted">
                                <i class="fas fa-clock text-primary me-1"></i>
                                @ev.EventDate.ToLocalTime().ToString("MMM dd, yyyy · h:mm tt")
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-0 px-3 pb-3 pt-0 d-flex gap-2">
                            <a href="/events/@ev.Id" class="btn btn-primary btn-sm flex-grow-1">
                                <i class="fas fa-eye me-1"></i>View
                            </a>
                            @if (Session.IsAdmin)
                            {
                                <a href="/events/edit/@ev.Id" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i></a>
                                <a href="/events/delete/@ev.Id" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
        <p class="text-muted mt-3 small">Showing @Filtered.Count() of @events.Count events</p>
    }
</div>

@code {
    private List<Event>? events;
    private string search     = "";
    private string catFilter  = "";
    private string venueFilter= "";
    private string timeFilter = "upcoming";

    private IEnumerable<string> AllVenues => events?
        .SelectMany(e => e.EventVenues.Select(ev => ev.Venue.Name))
        .Distinct().OrderBy(x => x) ?? Enumerable.Empty<string>();

    private IEnumerable<Event> Filtered => events?
        .Where(e => string.IsNullOrEmpty(search) ||
                    e.Title.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    e.Location.Contains(search, StringComparison.OrdinalIgnoreCase))
        .Where(e => string.IsNullOrEmpty(catFilter) || e.Category == catFilter)
        .Where(e => string.IsNullOrEmpty(venueFilter) ||
                    e.EventVenues.Any(ev => ev.Venue.Name == venueFilter))
        .Where(e => timeFilter == "all" ||
                    (timeFilter == "upcoming" && e.EventDate >= DateTime.UtcNow) ||
                    (timeFilter == "past"     && e.EventDate <  DateTime.UtcNow))
        .OrderBy(e => e.EventDate)
        ?? Enumerable.Empty<Event>();

    protected override async Task OnInitializedAsync()
    {
        events = await EventSvc.GetAllEventsAsync();
    }
}
