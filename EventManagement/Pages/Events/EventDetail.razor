@page "/events/{Id:int}"
@inject EventService EventSvc
@inject RegistrationService RegSvc
@inject SessionService Session
@inject NavigationManager Nav

<PageTitle>@(ev?.Title ?? "Event Detail") – EventHub</PageTitle>

@if (ev == null)
{
    <div class="container text-center py-5">
        <div class="spinner-border text-primary"></div>
    </div>
}
else
{
    var catKey  = (ev.Category ?? "general").ToLower().Replace(" ","");
    var venues  = ev.EventVenues.Select(v=>v.Venue).ToList();
    var acts    = ev.EventActivities.Select(a=>a.Activity).ToList();
    var fill    = ev.MaxCapacity > 0 ? (int)((double)ev.Registrations.Count/ev.MaxCapacity*100) : 0;
    var embedUrl= GetYouTubeEmbed(ev.VideoUrl);

    <div class="container">
        <nav aria-label="breadcrumb" class="mt-2 mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item"><a href="/events">Events</a></li>
                <li class="breadcrumb-item active">@ev.Title</li>
            </ol>
        </nav>

        <div class="row g-4">
            <!-- ── Main content ── -->
            <div class="col-lg-8">
                <div class="card">

                    <!-- Hero image or gradient header -->
                    @if (!string.IsNullOrEmpty(ev.ImageUrl))
                    {
                        <div class="detail-hero">
                            <img src="@ev.ImageUrl" alt="@ev.Title" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                            <!-- fallback gradient if image fails -->
                            <div class="event-card-header cat-@catKey" style="display:none;min-height:280px;align-items:flex-end;border-radius:var(--radius-lg) var(--radius-lg) 0 0">
                                <h2 class="text-white fw-bold" style="text-shadow:0 2px 8px rgba(0,0,0,.2)">@ev.Title</h2>
                            </div>
                            <div class="detail-hero-overlay">
                                <div class="d-flex gap-2 mb-2 flex-wrap">
                                    <span class="badge" style="background:rgba(255,255,255,.25);color:#fff;backdrop-filter:blur(6px)">@ev.Category</span>
                                    @if (Session.IsAdmin)
                                    {
                                        <a href="/events/edit/@ev.Id" class="btn btn-warning btn-sm ms-auto"><i class="fas fa-edit me-1"></i>Edit</a>
                                        <a href="/events/delete/@ev.Id" class="btn btn-danger btn-sm"><i class="fas fa-trash me-1"></i>Delete</a>
                                    }
                                </div>
                                <h2>@ev.Title</h2>
                                <div style="color:rgba(255,255,255,.8);font-size:.9rem;margin-top:.3rem">
                                    <i class="fas fa-calendar me-1"></i>@ev.EventDate.ToLocalTime().ToString("ddd, MMM dd yyyy · h:mm tt")
                                    &nbsp;·&nbsp;<i class="fas fa-map-marker-alt me-1"></i>@ev.Location
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- Category-coloured header if no image -->
                        <div class="event-card-header cat-@catKey p-4" style="border-radius:var(--radius-lg) var(--radius-lg) 0 0;min-height:180px;display:flex;flex-direction:column;justify-content:flex-end">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge" style="background:rgba(255,255,255,.25);color:#fff">@ev.Category</span>
                                @if (Session.IsAdmin)
                                {
                                    <div class="d-flex gap-2">
                                        <a href="/events/edit/@ev.Id" class="btn btn-warning btn-sm"><i class="fas fa-edit me-1"></i>Edit</a>
                                        <a href="/events/delete/@ev.Id" class="btn btn-danger btn-sm"><i class="fas fa-trash me-1"></i>Delete</a>
                                    </div>
                                }
                            </div>
                            <h2 class="text-white fw-bold mb-0" style="text-shadow:0 2px 8px rgba(0,0,0,.2)">@ev.Title</h2>
                            <div style="color:rgba(255,255,255,.75);font-size:.85rem;margin-top:.4rem">
                                <i class="fas fa-calendar me-1"></i>@ev.EventDate.ToLocalTime().ToString("ddd, MMM dd yyyy · h:mm tt")
                                &nbsp;·&nbsp;<i class="fas fa-map-marker-alt me-1"></i>@ev.Location
                            </div>
                        </div>
                    }

                    <div class="card-body p-4">
                        <!-- Key info grid -->
                        <div class="row g-3 mb-4">
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-3">
                                    <div style="width:42px;height:42px;border-radius:11px;background:#f0f4ff;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                        <i class="fas fa-calendar-alt text-primary"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted" style="font-size:.73rem;text-transform:uppercase;letter-spacing:.5px">Date &amp; Time</div>
                                        <div class="fw-bold">@ev.EventDate.ToLocalTime().ToString("ddd, MMM dd yyyy")</div>
                                        <div class="small text-muted">@ev.EventDate.ToLocalTime().ToString("h:mm tt")</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-3">
                                    <div style="width:42px;height:42px;border-radius:11px;background:#fef2f2;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                        <i class="fas fa-map-marker-alt text-danger"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted" style="font-size:.73rem;text-transform:uppercase;letter-spacing:.5px">City / Area</div>
                                        <div class="fw-bold">@ev.Location</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-3">
                                    <div style="width:42px;height:42px;border-radius:11px;background:#f0fdf4;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                        <i class="fas fa-users text-success"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted" style="font-size:.73rem;text-transform:uppercase;letter-spacing:.5px">Capacity</div>
                                        <div class="fw-bold">@ev.Registrations.Count / @ev.MaxCapacity</div>
                                        <div class="cap-bar mt-1" style="min-width:100px"><div class="cap-bar-fill" style="width:@fill%;background:linear-gradient(90deg,#10b981,#6366f1)"></div></div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-3">
                                    <div style="width:42px;height:42px;border-radius:11px;background:@(ev.Registrations.Count < ev.MaxCapacity ? "#f0fdf4" : "#fff5f5");display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                        <i class="fas fa-@(ev.Registrations.Count < ev.MaxCapacity ? "check-circle text-success" : "ban text-danger")"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted" style="font-size:.73rem;text-transform:uppercase;letter-spacing:.5px">Availability</div>
                                        <div class="fw-bold text-@(ev.Registrations.Count < ev.MaxCapacity ? "success" : "danger")">
                                            @(ev.Registrations.Count < ev.MaxCapacity ? (ev.MaxCapacity - ev.Registrations.Count) + " seats left" : "Fully Booked")
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Description -->
                        <h5 class="fw-bold mb-2"><i class="fas fa-align-left text-muted me-2"></i>About this Event</h5>
                        <p class="text-muted lh-lg" style="font-size:.95rem">@ev.Description</p>

                        <!-- Social Media Links -->
                        @{
                            var hasSocial = !string.IsNullOrEmpty(ev.WebsiteUrl)  ||
                                            !string.IsNullOrEmpty(ev.FacebookUrl)  ||
                                            !string.IsNullOrEmpty(ev.TwitterUrl)   ||
                                            !string.IsNullOrEmpty(ev.LinkedInUrl)  ||
                                            !string.IsNullOrEmpty(ev.InstagramUrl) ||
                                            !string.IsNullOrEmpty(ev.YoutubeUrl);
                        }
                        @if (hasSocial)
                        {
                            <h5 class="fw-bold mt-4 mb-2"><i class="fas fa-share-alt text-primary me-2"></i>Connect &amp; Follow</h5>
                            <div class="social-btns">
                                @if (!string.IsNullOrEmpty(ev.WebsiteUrl))
                                {
                                    <a href="@ev.WebsiteUrl" target="_blank" class="social-btn website">
                                        <i class="fas fa-globe"></i> Official Website
                                    </a>
                                }
                                @if (!string.IsNullOrEmpty(ev.FacebookUrl))
                                {
                                    <a href="@ev.FacebookUrl" target="_blank" class="social-btn facebook">
                                        <i class="fab fa-facebook-f"></i> Facebook
                                    </a>
                                }
                                @if (!string.IsNullOrEmpty(ev.TwitterUrl))
                                {
                                    <a href="@ev.TwitterUrl" target="_blank" class="social-btn twitter">
                                        <i class="fab fa-x-twitter"></i> X (Twitter)
                                    </a>
                                }
                                @if (!string.IsNullOrEmpty(ev.LinkedInUrl))
                                {
                                    <a href="@ev.LinkedInUrl" target="_blank" class="social-btn linkedin">
                                        <i class="fab fa-linkedin-in"></i> LinkedIn
                                    </a>
                                }
                                @if (!string.IsNullOrEmpty(ev.InstagramUrl))
                                {
                                    <a href="@ev.InstagramUrl" target="_blank" class="social-btn instagram">
                                        <i class="fab fa-instagram"></i> Instagram
                                    </a>
                                }
                                @if (!string.IsNullOrEmpty(ev.YoutubeUrl))
                                {
                                    <a href="@ev.YoutubeUrl" target="_blank" class="social-btn youtube">
                                        <i class="fab fa-youtube"></i> YouTube
                                    </a>
                                }
                            </div>
                        }

                        <!-- Video embed -->
                        @if (!string.IsNullOrEmpty(embedUrl))
                        {
                            <h5 class="fw-bold mt-4 mb-3"><i class="fas fa-play-circle text-danger me-2"></i>Event Video</h5>
                            <div class="video-wrap mb-2">
                                <iframe src="@embedUrl" allowfullscreen allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"></iframe>
                            </div>
                        }

                        <!-- Venues -->
                        @if (venues.Any())
                        {
                            <h5 class="fw-bold mt-4 mb-3"><i class="fas fa-map-marker-alt text-danger me-2"></i>Venues</h5>
                            <div class="row g-3">
                                @foreach (var v in venues)
                                {
                                    <div class="col-md-6">
                                        <div class="card h-100" style="border:1.5px solid #bae6fd;background:#f0f9ff">
                                            <div class="card-body p-3">
                                                <div class="fw-bold mb-1"><i class="fas fa-building text-info me-2"></i>@v.Name</div>
                                                <div class="text-muted small"><i class="fas fa-map-pin me-1"></i>@v.Address, @v.City</div>
                                                <div class="text-muted small"><i class="fas fa-users me-1"></i>Capacity: @v.Capacity</div>
                                                @if (!string.IsNullOrEmpty(v.Description))
                                                {
                                                    <p class="text-muted small mt-1 mb-0">@v.Description</p>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        <!-- Activities -->
                        @if (acts.Any())
                        {
                            <h5 class="fw-bold mt-4 mb-3"><i class="fas fa-tasks text-primary me-2"></i>Activities &amp; Schedule</h5>
                            <div class="row g-3">
                                @foreach (var a in acts)
                                {
                                    var tc = "act-" + a.Type.ToLower();
                                    <div class="col-md-6">
                                        <div class="card h-100" style="border:1.5px solid #ddd6fe;background:#f5f3ff">
                                            <div class="card-body p-3">
                                                <div class="d-flex justify-content-between align-items-start">
                                                    <div class="fw-bold mb-1">@a.Name</div>
                                                    <span class="pill-tag @tc flex-shrink-0 ms-2">@a.Type</span>
                                                </div>
                                                @if (!string.IsNullOrEmpty(a.Description))
                                                {
                                                    <p class="text-muted small mb-1">@a.Description</p>
                                                }
                                                <div class="text-muted small"><i class="fas fa-clock me-1"></i>@a.DurationMinutes min</div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- ── Registration sidebar ── -->
            <div class="col-lg-4">
                <div class="card sticky-top" style="top:20px">
                    <div class="card-header py-3" style="background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;border-radius:var(--radius-lg) var(--radius-lg) 0 0">
                        <h5 class="mb-0"><i class="fas fa-ticket-alt me-2"></i>Registration</h5>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(message))
                        {
                            <div class="alert alert-@msgType alert-dismissible py-2 mb-3">
                                @message
                                <button type="button" class="btn-close btn-sm" @onclick="() => message = null"></button>
                            </div>
                        }
                        @if (!Session.IsAuthenticated)
                        {
                            <p class="text-muted small">Please login to register for this event.</p>
                            <a href="/login" class="btn btn-primary w-100"><i class="fas fa-sign-in-alt me-1"></i>Login to Register</a>
                        }
                        else if (ev.EventDate < DateTime.UtcNow)
                        {
                            <div class="alert alert-secondary py-2"><i class="fas fa-clock me-2"></i>This event has ended.</div>
                        }
                        else if (isRegistered)
                        {
                            <div class="alert alert-success py-2"><i class="fas fa-check-circle me-2"></i>You're registered!</div>
                            <button class="btn btn-outline-danger w-100 mt-2" @onclick="Unregister" disabled="@processing">
                                @if (processing) { <span class="spinner-border spinner-border-sm me-2"></span> }
                                <i class="fas fa-times me-1"></i>Cancel Registration
                            </button>
                        }
                        else if (ev.Registrations.Count >= ev.MaxCapacity)
                        {
                            <div class="alert alert-danger py-2"><i class="fas fa-ban me-2"></i>This event is fully booked.</div>
                        }
                        else
                        {
                            <button class="btn btn-primary w-100 py-2" @onclick="Register" disabled="@processing">
                                @if (processing) { <span class="spinner-border spinner-border-sm me-2"></span> }
                                <i class="fas fa-ticket-alt me-2"></i>Register Now
                            </button>
                            <p class="text-muted small text-center mt-2 mb-0">@(ev.MaxCapacity - ev.Registrations.Count) seats remaining</p>
                        }
                    </div>
                </div>

                <!-- Share links in sidebar too -->
                @if (hasSocial)
                {
                    <div class="card mt-3">
                        <div class="card-header"><h6 class="mb-0"><i class="fas fa-share-alt me-2"></i>Share &amp; Follow</h6></div>
                        <div class="card-body pb-3">
                            <div class="social-btns">
                                @if (!string.IsNullOrEmpty(ev.WebsiteUrl))
                                { <a href="@ev.WebsiteUrl" target="_blank" class="social-btn website"><i class="fas fa-globe"></i> Website</a> }
                                @if (!string.IsNullOrEmpty(ev.FacebookUrl))
                                { <a href="@ev.FacebookUrl" target="_blank" class="social-btn facebook"><i class="fab fa-facebook-f"></i></a> }
                                @if (!string.IsNullOrEmpty(ev.TwitterUrl))
                                { <a href="@ev.TwitterUrl" target="_blank" class="social-btn twitter"><i class="fab fa-x-twitter"></i></a> }
                                @if (!string.IsNullOrEmpty(ev.LinkedInUrl))
                                { <a href="@ev.LinkedInUrl" target="_blank" class="social-btn linkedin"><i class="fab fa-linkedin-in"></i></a> }
                                @if (!string.IsNullOrEmpty(ev.InstagramUrl))
                                { <a href="@ev.InstagramUrl" target="_blank" class="social-btn instagram"><i class="fab fa-instagram"></i></a> }
                                @if (!string.IsNullOrEmpty(ev.YoutubeUrl))
                                { <a href="@ev.YoutubeUrl" target="_blank" class="social-btn youtube"><i class="fab fa-youtube"></i></a> }
                            </div>
                        </div>
                    </div>
                }

                <!-- Attendees (admin) -->
                @if (Session.IsAdmin && ev.Registrations.Any())
                {
                    <div class="card mt-3">
                        <div class="card-header"><h6 class="mb-0"><i class="fas fa-users me-2"></i>Attendees (@ev.Registrations.Count)</h6></div>
                        <div class="card-body p-0">
                            <ul class="list-group list-group-flush">
                                @foreach (var r in ev.Registrations.OrderByDescending(r=>r.RegisteredAt).Take(10))
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center py-2 px-3">
                                        <span class="small"><i class="fas fa-user-circle me-2 text-muted"></i>@r.User.FullName</span>
                                        <span class="@("status-" + r.Status.ToString().ToLower())">@r.Status</span>
                                    </li>
                                }
                                @if (ev.Registrations.Count > 10)
                                {
                                    <li class="list-group-item text-center text-muted small">+@(ev.Registrations.Count - 10) more</li>
                                }
                            </ul>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private Event? ev;
    private bool isRegistered, processing;
    private string? message;
    private string msgType = "success";

    protected override async Task OnParametersSetAsync()
    {
        ev = await EventSvc.GetEventByIdAsync(Id);
        if (ev == null) { Nav.NavigateTo("/events"); return; }
        if (Session.IsAuthenticated)
            isRegistered = await RegSvc.IsRegisteredAsync(Session.CurrentUser!.Id, Id);
    }

    private async Task Register()
    {
        if (!Session.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        processing = true;
        var (ok, msg) = await RegSvc.RegisterAsync(Session.CurrentUser!.Id, Id);
        processing = false; message = msg; msgType = ok ? "success" : "danger";
        if (ok) { isRegistered = true; ev = await EventSvc.GetEventByIdAsync(Id); }
    }

    private async Task Unregister()
    {
        processing = true;
        var (ok, msg) = await RegSvc.UnregisterAsync(Session.CurrentUser!.Id, Id);
        processing = false; message = msg; msgType = ok ? "info" : "danger";
        if (ok) { isRegistered = false; ev = await EventSvc.GetEventByIdAsync(Id); }
    }

    /// <summary>Convert any YouTube watch URL to an embed URL.</summary>
    private static string? GetYouTubeEmbed(string? url)
    {
        if (string.IsNullOrEmpty(url)) return null;
        try
        {
            var uri = new Uri(url);
            // youtu.be/ID  or  youtube.com/watch?v=ID
            string? videoId = null;
            if (uri.Host.Contains("youtu.be"))
                videoId = uri.AbsolutePath.TrimStart('/');
            else if (uri.Host.Contains("youtube.com"))
            {
                var q = System.Web.HttpUtility.ParseQueryString(uri.Query);
                videoId = q["v"];
            }
            return videoId != null ? $"https://www.youtube.com/embed/{videoId}?rel=0" : null;
        }
        catch { return null; }
    }
}
