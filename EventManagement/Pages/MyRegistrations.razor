@page "/my-registrations"
@inject RegistrationService RegSvc
@inject SessionService Session
@inject NavigationManager Nav

<PageTitle>My Registrations – EventHub</PageTitle>

<div class="container">
    <div class="page-header">
        <div>
            <h2 class="section-title mb-1"><i class="fas fa-ticket-alt text-primary me-2"></i>My Registrations</h2>
            <p class="section-subtitle mb-0">Track all your event registrations</p>
        </div>
        <a href="/events" class="btn btn-outline-primary"><i class="fas fa-compass me-1"></i>Browse Events</a>
    </div>

    @if (!Session.IsAuthenticated)
    {
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-circle me-2"></i>
            Please <a href="/login">login</a> to view your registrations.
        </div>
    }
    else if (registrations == null)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (!registrations.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon"><i class="fas fa-ticket-alt"></i></div>
            <h5>No registrations yet</h5>
            <p class="small">Browse events and register to see them here.</p>
            <a href="/events" class="btn btn-primary mt-2"><i class="fas fa-compass me-1"></i>Browse Events</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var reg in registrations.OrderBy(r => r.Event.EventDate))
            {
                var isPast  = reg.Event.EventDate < DateTime.UtcNow;
                var catKey  = (reg.Event.Category ?? "general").ToLower().Replace(" ","");
                var icon    = reg.Event.Category switch {
                    "Technology"    => "fa-microchip",
                    "Business"      => "fa-briefcase",
                    "Health"        => "fa-heartbeat",
                    "Education"     => "fa-graduation-cap",
                    "Entertainment" => "fa-music",
                    _               => "fa-calendar-alt"
                };
                var venues = reg.Event.EventVenues.Select(ev => ev.Venue.Name).ToList();
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 event-card @(isPast?"opacity-75":"")">
                        <div class="event-card-header cat-@catKey">
                            <div class="event-card-icon"><i class="fas @icon"></i></div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="badge" style="background:rgba(255,255,255,.25);color:#fff">@reg.Event.Category</span>
                                <span class="@("status-" + reg.Status.ToString().ToLower())">@reg.Status</span>
                            </div>
                        </div>
                        <div class="card-body d-flex flex-column p-3">
                            <h5 class="fw-bold mb-2" style="font-size:.97rem">@reg.Event.Title</h5>
                            @if (venues.Any())
                            {
                                <div class="mb-2">
                                    @foreach (var v in venues.Take(2))
                                    { <span class="pill-tag venue"><i class="fas fa-map-marker-alt"></i>@v</span> }
                                </div>
                            }
                            else
                            {
                                <p class="small text-muted mb-1"><i class="fas fa-map-marker-alt text-danger me-1"></i>@reg.Event.Location</p>
                            }
                            <div class="small text-muted mb-1 mt-auto">
                                <i class="fas fa-calendar text-primary me-1"></i>
                                @reg.Event.EventDate.ToLocalTime().ToString("MMM dd, yyyy · h:mm tt")
                            </div>
                            <div class="small text-muted">
                                <i class="fas fa-clock me-1"></i>Registered @reg.RegisteredAt.ToLocalTime().ToString("MMM dd, yyyy")
                            </div>
                            @if (isPast)
                            {
                                <span class="badge bg-secondary mt-2">Event ended</span>
                            }
                        </div>
                        <div class="card-footer bg-transparent border-0 px-3 pb-3 pt-0 d-flex gap-2">
                            <a href="/events/@reg.EventId" class="btn btn-primary btn-sm flex-grow-1">
                                <i class="fas fa-eye me-1"></i>View Event
                            </a>
                            @if (!isPast && reg.Status != RegistrationStatus.Cancelled)
                            {
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => Unregister(reg.EventId)" title="Cancel">
                                    <i class="fas fa-times"></i>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<EventRegistration>? registrations;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated) return;
        registrations = await RegSvc.GetUserRegistrationsAsync(Session.CurrentUser!.Id);
    }

    private async Task Unregister(int eventId)
    {
        await RegSvc.UnregisterAsync(Session.CurrentUser!.Id, eventId);
        registrations = await RegSvc.GetUserRegistrationsAsync(Session.CurrentUser!.Id);
    }
}
